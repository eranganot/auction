# ---- Server ----
PORT=3000

# ---- Database (Railway provides DATABASE_URL automatically) ----
DATABASE_URL=postgresql://user:password@localhost:5432/bidspirit?schema=public

# ---- Telegram notifications ----
TELEGRAM_BOT_TOKEN=
# Comma-separated list of chat IDs, e.g. 12345678,-1009876543
TELEGRAM_CHAT_IDS=

# ---- Email notifications (SMTP via Nodemailer) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Comma-separated recipient list
NOTIFICATION_EMAILS=
# From header (optional; defaults to SMTP_USER)
SMTP_FROM=

# ---- Scraper behaviour ----
SCRAPER_HEADLESS=true
SCRAPER_TIMEOUT=45000
SCRAPER_DELAY_MIN=800
SCRAPER_DELAY_MAX=2500
# Daily cron schedule (node-cron syntax). Default 06:00 Asia/Jerusalem.
SCRAPER_CRON=0 6 * * *
SCRAPER_TZ=Asia/Jerusalem
# Minutes after which a stuck RUNNING scrape is reaped (crash recovery).
SCRAPER_STALE_RUN_MINUTES=120
# Set to "true" on the Railway cron service so the worker runs once and exits.
RUN_ONCE=false
# Persistent scheduled worker only: also run one cycle immediately on boot,
# so a fresh deploy populates the DB without waiting for the next cron tick.
RUN_ON_START=false

# ---- Misc ----
# Region/content are fixed for Bidspirit Cars IL but kept configurable.
BIDSPIRIT_REGION=IL
BIDSPIRIT_CONTENT=CARS
LOG_LEVEL=info

# ---- Web Push (browser notifications) ----
# Generate a keypair once with: npx web-push generate-vapid-keys
# Web push is disabled unless BOTH keys are set (Telegram/Email/in-app still work).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@bidspirit.local
